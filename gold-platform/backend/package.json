{
  "name": "gold-platform-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute gold-platform-db --local --file=migrations/0001_init.sql",
